---
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import '../styles/base.css';
interface Props { title?: string; description?: string; }
const {
  title = 'The Ninja-360 Dojo',
  description = 'The Ninja-360 Dojo — the plan, the crew, and the playbooks in one place.',
} = Astro.props;

// Share-card metadata. Absolute URL required — link previews (iMessage,
// WhatsApp, SMS) won't resolve relative og:image paths.
const shareImage = 'https://dojo.ninja360.co/share/map-master.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Ninja-360 Dojo" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:image:alt" content="M.A.P. Master — Full System Marketing badge" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <TopBar />
    <div class="wrap">
      <slot />
    </div>
    <Footer />
  </body>
</html>
