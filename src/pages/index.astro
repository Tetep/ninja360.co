---
// Home — three-act cinematic story:
//   ACT 0 · PICKER   Who are you? (5 cards — 4 ninjas + guest)
//   ACT 1 · CALL     Do you accept? (personalized by identity)
//   ACT 2+ · ORIGIN / PHILOSOPHIES / NEXT PHASE / DOJO
//
// Phase state stored on <html data-phase>:
//   "picker"  → only Act 0 visible
//   "call"    → only Act 1 visible (identity chosen, awaiting accept)
//   (unset)   → everything visible (accepted OR guest)
//
// localStorage keys:
//   dojo:identity  → 'tim' | 'gabe' | 'pavan' | 'erik' | 'guest'
//   dojo:accepted  → 'true'
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import DojoLayout from '../layouts/DojoLayout.astro';
import Torii from '../components/Torii.astro';
import Door from '../components/Door.astro';
import { doorImages, heroFlankImage } from '../assets/doors';
import { crewBanners, crewEmblems } from '../assets/crew';

const rooms = (await getCollection('rooms')).sort(
  (a, b) => a.data.order - b.data.order
);
const timBanner = crewBanners['crew-tim-banner.png'];

// Identity roster — single source for card copy + personalized Call text.
// Only Tim gets a quote on his card (per Tim's ask).
const identities = [
  { id: 'tim',   name: 'Tim Petet',       role: 'Sensei · Head Ninja',      accent: 'sensei',    emblem: crewEmblems['crew-tim-emblem.png'],   action: 'LEAD',      sub: 'The Dojo is yours to build.',      quote: 'I help Kansas City businesses get found and chosen on Google.' },
  { id: 'gabe',  name: 'Gabriel Miller',  role: 'Creative · Video Ninja',   accent: 'creative',  emblem: crewEmblems['crew-gabe-emblem.png'],  action: 'TELL',      sub: 'Every frame is your canvas.' },
  { id: 'pavan', name: 'Pavan Ganta',     role: 'Architect · Dev Ninja',    accent: 'architect', emblem: crewEmblems['crew-pavan-emblem.png'], action: 'BUILD',     sub: 'The systems are yours to wire.' },
  { id: 'erik',  name: 'Erik Juergensen', role: 'Ally · Podcast Ninja',     accent: 'ally',      emblem: crewEmblems['crew-erik-emblem.png'],  action: 'BROADCAST', sub: 'Lucky 13 is the home stage.' },
];
---

<DojoLayout title="The Ninja-360 Dojo">

  {/* Set initial phase before any scene paints — prevents flash of wrong content.
      New visitors → PICKER. Returning visitors with identity but no accept → CALL.
      Fully-accepted (or guest) visitors → no phase set → everything visible. */}
  <script is:inline>
    (function () {
      try {
        var id = localStorage.getItem('dojo:identity');
        var ok = localStorage.getItem('dojo:accepted');
        if (!id) document.documentElement.dataset.phase = 'picker';
        else if (!ok) document.documentElement.dataset.phase = 'call';
      } catch (_) {
        document.documentElement.dataset.phase = 'picker';
      }
    })();
  </script>

  {/* ============================================================
      ACT 0 · THE PICKER — Who are you?
      ============================================================ */}
  <section class="scene-picker" aria-labelledby="picker-title">
    <div class="picker-inner">
      <p class="picker-kicker fade fade-1">THE 90-DAY SPRINT · V01</p>
      <h1 id="picker-title" class="picker-title fade fade-2">Who are you?</h1>
      <p class="picker-lead fade fade-3">Every mission starts with an identity.</p>

      <div class="ninja-grid fade fade-4" role="radiogroup" aria-label="Choose your identity">
        {identities.map(n => (
          <button
            type="button"
            class={`ninja-card accent-${n.accent}`}
            data-ninja={n.id}
            role="radio"
            aria-checked="false"
            aria-label={`I am ${n.name}, ${n.role}`}
          >
            <div class="card-glow" aria-hidden="true"></div>
            <div class="card-portrait">
              <Image
                src={n.emblem}
                alt=""
                loading="eager"
                widths={[240, 360, 480]}
                sizes="(max-width: 640px) 44vw, 220px"
              />
            </div>
            <div class="card-meta">
              <div class="card-name">{n.name}</div>
              <div class="card-role">{n.role}</div>
              {n.quote && <div class="card-quote">"{n.quote}"</div>}
            </div>
          </button>
        ))}
      </div>

      <button type="button" class="guest-link fade fade-5" data-ninja="guest" data-guest="true">
        I'm just visiting — show me the Dojo &rarr;
      </button>
    </div>
  </section>

  {/* ============================================================
      ACT 1 · THE CALL — Do you accept? (personalized)
      ============================================================ */}
  <section class="scene-call" aria-labelledby="call-title">
    <div class="call-chip" id="call-chip" aria-live="polite">
      <span class="chip-arrow">↳</span>
      <span class="chip-name" id="chip-name">—</span>
      <span class="chip-sep">·</span>
      <button type="button" id="reset-identity" class="chip-reset">not you?</button>
    </div>

    <div class="call-inner">
      <p class="call-kicker fade fade-1">THE 90-DAY SPRINT · V01</p>
      <h1 id="call-title" class="call-title fade fade-2">
        You've been <span class="orange">drafted.</span>
      </h1>
      <div class="call-emblem fade fade-3" id="call-emblem">
        {identities.map(n => (
          <Image
            src={n.emblem}
            alt={`${n.name} — ninja emblem`}
            data-for={n.id}
            loading="eager"
            widths={[320, 480, 640]}
            sizes="(max-width: 640px) 68vw, 320px"
          />
        ))}
      </div>
      <p class="call-body fade fade-4">
        This is the 90-day sprint to elevate Ninja-360 into the Key Person of
        Influence brand of the Kansas City metro — and you're part of how we
        get there.
      </p>
      <p class="call-ask fade fade-5">Do you accept?</p>
      <div class="call-actions fade fade-6">
        <button type="button" id="accept-btn" class="btn-accept">I accept &rarr; take me inside</button>
        <a href="/gameplan" class="btn-skip">Skip to the Game Plan</a>
      </div>
      <p class="call-hint fade fade-7" aria-hidden="true">↑ accept to unlock</p>
    </div>
  </section>

  {/* ============================================================
      ACT 2 · THE ORIGIN — This is Ninja-360.
      ============================================================ */}
  <section id="origin" class="scene scene-origin">
    <div class="scene-wrap">
      <p class="scene-kicker">THIS IS NINJA-360</p>
      <h2 class="scene-title">Ten years of putting Kansas City on the map.</h2>
      <p class="scene-lede">
        Since the beginning, Tim Petet has been quietly documenting the Kansas City
        metro from every angle — drone captures, 360 virtual tours, and cinematic
        media for the businesses that make this city run. That work has racked up
        a quiet superpower most agencies would kill for.
      </p>

      <div class="hero-reel">
        <video
          src="/assets/video/ninja-hero-16x9-V01.mp4"
          muted loop playsinline autoplay preload="metadata"
          aria-label="Ninja-360 hero animation"
        ></video>
      </div>

      <div class="portrait-wrap">
        <Image
          class="portrait-img"
          src={timBanner}
          alt="Tim Petet — Ninja-360"
          loading="lazy"
          widths={[240, 360, 480]}
          sizes="(max-width: 640px) 60vw, 240px"
        />
        <div class="portrait-caption">Tim Petet · Founder · Ninja-360 Digital Media LLC</div>
      </div>

      <div class="moat" aria-label="Ninja-360 authority signals">
        <div class="moat-item">
          <div class="moat-n">90M<span class="plus">+</span></div>
          <div class="moat-l">Google Photos &amp; Virtual Tour views</div>
        </div>
        <div class="moat-sep" aria-hidden="true"></div>
        <div class="moat-item">
          <div class="moat-n">10 <span class="unit">years</span></div>
          <div class="moat-l">documenting the KC metro — since 2016</div>
        </div>
        <div class="moat-sep" aria-hidden="true"></div>
        <div class="moat-item">
          <div class="moat-n">KC<span class="plus">.</span></div>
          <div class="moat-l">Owner-operated from Gladstone, MO</div>
        </div>
      </div>
    </div>
  </section>

  {/* ACT 3 · THE PHILOSOPHIES — the fancy scroll */}
  <section class="scene scene-philosophies" id="philosophies">
    {/* Incense drift — decorative, never intercepts input */}
    <div class="phil-smoke" aria-hidden="true">
      <svg viewBox="0 0 900 600" preserveAspectRatio="none">
        <path class="w"  d="M120 620 C 160 480, 60 420, 140 300 C 210 200, 120 140, 180 40"  fill="none" stroke="#F4C88E" stroke-width="26" stroke-linecap="round"/>
        <path class="w w2" d="M460 640 C 420 500, 540 440, 470 320 C 400 210, 520 150, 460 60" fill="none" stroke="#F4C88E" stroke-width="20" stroke-linecap="round"/>
        <path class="w w3" d="M780 620 C 820 470, 720 430, 790 310 C 850 210, 760 150, 820 50" fill="none" stroke="#F4C88E" stroke-width="24" stroke-linecap="round"/>
      </svg>
    </div>

    <div class="scene-wrap">
      <div class="phil-ornament" aria-hidden="true"><span>◆</span></div>
      <p class="phil-kicker">The Way of Ninja-360</p>
      <h2 class="phil-title">
        <span class="phil-title-lead">The Three</span>
        <span class="phil-title-main">Core Philosophies</span>
        <span class="phil-title-tail">— of Ninja-360.</span>
      </h2>
      <p class="phil-lede">
        Every project, every pitch, every crew decision answers to one of these — or it doesn't get a lane.
      </p>

      {/* Ink-brush stroke divider */}
      <div class="phil-brush" aria-hidden="true">
        <svg viewBox="0 0 320 24" preserveAspectRatio="none">
          <path d="M4 14 C 60 8, 110 18, 160 12 C 214 6, 262 16, 316 10"
                fill="none" stroke="var(--orange)" stroke-width="3.5" stroke-linecap="round" opacity="0.85"/>
          <path d="M40 17 C 100 13, 200 17, 280 13"
                fill="none" stroke="var(--orange)" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
        </svg>
      </div>

      <div class="phil-grid">
        <article class="phil-card phil-card-1 kake">
          <div class="kake-cord" aria-hidden="true"></div>
          <div class="kake-rod" aria-hidden="true"></div>
          <div class="kake-body">
            <span class="kake-kanji" aria-hidden="true">一</span>
            <div class="kake-content">
              <div class="phil-roman" role="img" aria-label="One">
                <svg viewBox="0 0 46 110" class="rn">
                  <defs>
                    <linearGradient id="rg1" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0" stop-color="#F47920"/><stop offset=".6" stop-color="#E05F00"/><stop offset="1" stop-color="#A54200"/>
                    </linearGradient>
                    <filter id="rf1" x="-20%" y="-10%" width="140%" height="120%">
                      <feTurbulence type="fractalNoise" baseFrequency="0.021 0.036" numOctaves="2" seed="7" result="n"/>
                      <feDisplacementMap in="SourceGraphic" in2="n" scale="3.4"/>
                    </filter>
                    <path id="rp1" d="M-8,15 C-11,17 -11,22 -10,28 L-9,82 C-10,89 -6,95 0,95 C6,95 10,89 9,82 L10,28 C11,22 11,17 8,15 C4,13 -4,13 -8,15 Z"/>
                  </defs>
                  <g fill="url(#rg1)" filter="url(#rf1)">
                    <use href="#rp1" transform="translate(23 0)"/>
                  </g>
                </svg>
              </div>
              <h3 class="phil-h">Put People<br />on the Map.</h3>
              <p class="phil-sub">Visible. Heard. Chosen.</p>
              <ul class="phil-points">
                <li>Deserving KC businesses, made visible</li>
                <li>The M.A.P. Method — Make · Amplify · Promote</li>
                <li>The outcome we sell: found &amp; chosen on Google</li>
              </ul>
            </div>
          </div>
          <div class="kake-rod kake-rod-b" aria-hidden="true"></div>
        </article>

        <article class="phil-card phil-card-2 kake">
          <div class="kake-cord" aria-hidden="true"></div>
          <div class="kake-rod" aria-hidden="true"></div>
          <div class="kake-body">
            <span class="kake-kanji" aria-hidden="true">二</span>
            <div class="kake-content">
              <div class="phil-roman" role="img" aria-label="Two">
                <svg viewBox="0 0 84 110" class="rn">
                  <defs>
                    <linearGradient id="rg2" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0" stop-color="#F47920"/><stop offset=".6" stop-color="#E05F00"/><stop offset="1" stop-color="#A54200"/>
                    </linearGradient>
                    <filter id="rf2" x="-15%" y="-10%" width="130%" height="120%">
                      <feTurbulence type="fractalNoise" baseFrequency="0.021 0.036" numOctaves="2" seed="4" result="n"/>
                      <feDisplacementMap in="SourceGraphic" in2="n" scale="3.4"/>
                    </filter>
                    <path id="rp2" d="M-7,15 C-10,17 -10,22 -9,28 L-8,82 C-9,89 -5,95 0,95 C5,95 9,89 8,82 L9,28 C10,22 10,17 7,15 C4,13 -3,13 -7,15 Z"/>
                  </defs>
                  <g fill="url(#rg2)" filter="url(#rf2)">
                    <use href="#rp2" transform="translate(27 0)"/>
                    <use href="#rp2" transform="translate(57 0)"/>
                  </g>
                </svg>
              </div>
              <h3 class="phil-h">Fall in Love with<br />the True Story.</h3>
              <p class="phil-sub">Technology is the tool. Connection is the goal.</p>
              <ul class="phil-points">
                <li>Seek the authentic heart of every client</li>
                <li>Drones, 360s &amp; cinema serve the story — never replace it</li>
                <li>Real places, real people — never staged, never stock</li>
              </ul>
            </div>
          </div>
          <div class="kake-rod kake-rod-b" aria-hidden="true"></div>
        </article>

        <article class="phil-card phil-card-3 kake">
          <div class="kake-cord" aria-hidden="true"></div>
          <div class="kake-rod" aria-hidden="true"></div>
          <div class="kake-body">
            <span class="kake-kanji" aria-hidden="true">三</span>
            <div class="kake-content">
              <div class="phil-roman" role="img" aria-label="Three">
                <svg viewBox="0 0 124 110" class="rn">
                  <defs>
                    <linearGradient id="rg3" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0" stop-color="#F47920"/><stop offset=".6" stop-color="#E05F00"/><stop offset="1" stop-color="#A54200"/>
                    </linearGradient>
                    <filter id="rf3" x="-12%" y="-10%" width="124%" height="120%">
                      <feTurbulence type="fractalNoise" baseFrequency="0.021 0.036" numOctaves="2" seed="11" result="n"/>
                      <feDisplacementMap in="SourceGraphic" in2="n" scale="3.4"/>
                    </filter>
                    <path id="rp3" d="M-7,15 C-10,17 -10,22 -9,28 L-8,82 C-9,89 -5,95 0,95 C5,95 9,89 8,82 L9,28 C10,22 10,17 7,15 C4,13 -3,13 -7,15 Z"/>
                  </defs>
                  <g fill="url(#rg3)" filter="url(#rf3)">
                    <use href="#rp3" transform="translate(26 0)"/>
                    <use href="#rp3" transform="translate(62 0)"/>
                    <use href="#rp3" transform="translate(98 0)"/>
                  </g>
                </svg>
              </div>
              <h3 class="phil-h">Always Sharpen<br />the Blade.</h3>
              <p class="phil-sub">Cutting edge, never reckless.</p>
              <ul class="phil-points">
                <li>Research, experiment, disciplined execution</li>
                <li>Try, fail, learn, improve — with honest reflection</li>
                <li>Innovate responsibly, in service of the client</li>
              </ul>
            </div>
          </div>
          <div class="kake-rod kake-rod-b" aria-hidden="true"></div>
        </article>
      </div>
    </div>
  </section>

  {/* ACT 4 · THE NEXT PHASE */}
  <section class="scene scene-phase">
    <div class="scene-wrap">
      <p class="scene-kicker">THE NEXT PHASE</p>
      <h2 class="scene-title">Ninja-360, elevated.</h2>
      <p class="scene-lede">
        The last decade built the foundation. The next 90 days build the
        <b>brand</b> — a refined, automated, crew-operated Ninja-360 that becomes
        the name Kansas City reaches for when a local business needs to get found.
      </p>
      <p class="scene-lede">
        The Game Plan is the master charter — who does what, and by when. Read it
        first. Then walk the seven rooms of the Dojo.
      </p>
      <div class="phase-actions">
        <a href="/gameplan" class="btn-primary">Open the Game Plan &rarr;</a>
        <a href="#dojo-wall" class="btn-ghost">Enter the Dojo</a>
      </div>
    </div>
  </section>

  {/* ACT 5 · THE DOJO */}
  <section id="dojo-wall" class="scene scene-dojo" aria-labelledby="dojo-heading">
    <div class="scene-wrap">
      <div class="head-row">
        <Image class="head-flank head-flank-left" src={heroFlankImage} alt="" loading="lazy" widths={[180, 260, 360]} sizes="(max-width: 640px) 150px, 170px" />
        <div class="dojo-head">
          <Torii />
          <h2 id="dojo-heading">The Dojo</h2>
          <div class="sub">Seven rooms of the plan. Walk them in order — the doors are the milestones.</div>
        </div>
        <Image class="head-flank head-flank-right" src={heroFlankImage} alt="" loading="lazy" widths={[180, 260, 360]} sizes="(max-width: 640px) 150px, 170px" />
      </div>
      <div class="wall">
        {rooms.map(r => (
          <Door
            href={`/${r.slug}`}
            num={r.data.doorNum}
            lintel={r.data.doorLabel}
            name={r.data.title.split('—')[0].trim().replace(/^The\s+/, '')}
            sub={r.data.subtitle}
            imageSrc={doorImages[r.slug as keyof typeof doorImages]}
            variant={r.slug === 'floor' ? 'floor' : 'default'}
          />
        ))}
        <Door href="#" num="★" lintel="Someday" name="The App" sub="This board, upgraded · parked" variant="parked" />
      </div>
      <p class="tagline">Run the rhythm. The rhythm runs the plan.</p>
    </div>
  </section>
</DojoLayout>

<style>
  /* =====================================================================
     Full-bleed black cinematic canvas — shared by Picker + Call
     ===================================================================== */
  .scene-picker,
  .scene-call {
    position: relative;
    min-height: calc(100vh - var(--bar-h) - 8px);
    background:
      radial-gradient(1200px 800px at 50% -10%, rgba(244, 121, 32, 0.10), transparent 60%),
      radial-gradient(800px 600px at 15% 90%, rgba(244, 121, 32, 0.06), transparent 70%),
      linear-gradient(180deg, #0F0F10 0%, #1A1A1B 60%, #0B0B0C 100%);
    color: #F2EAE0;
    display: flex; align-items: center; justify-content: center;
    padding: 60px 24px;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-top: -26px;
    overflow: hidden;
  }
  .scene-call { margin-top: 0; }
  .scene-picker::before,
  .scene-call::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--texture-paper);
    opacity: 0.4;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* =====================================================================
     Ninja Hero reel — the Origin scene showcase
     ===================================================================== */
  .hero-reel {
    max-width: 760px;
    margin: 34px auto 0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-2, 0 12px 32px rgba(0, 0, 0, 0.25));
    border: 1px solid rgba(244, 121, 32, 0.25);
    line-height: 0;
  }
  .hero-reel video {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-reel { display: none; }
  }
  @media (max-width: 640px) {
    .hero-reel { margin-top: 24px; border-radius: 10px; }
  }

  /* =====================================================================
     ACT 0 · THE PICKER — Who are you?
     ===================================================================== */
  .picker-inner {
    position: relative;
    max-width: 1100px;
    width: 100%;
    text-align: center;
    z-index: 1;
  }
  .picker-kicker {
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 4px;
    font-size: 12px; color: var(--orange);
    margin-bottom: 14px;
  }
  .picker-title {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(40px, 7vw, 74px); line-height: 0.95;
    color: #FFFFFF; text-transform: uppercase; letter-spacing: 1px;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.4);
  }
  .picker-lead {
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px;
    font-size: clamp(13px, 1.8vw, 16px);
    color: #C8BFB5; margin: 12px 0 0;
    opacity: 0.9;
  }

  .ninja-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin: 38px 0 24px;
  }

  /* --- Card --- */
  .ninja-card {
    position: relative;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: var(--r-lg);
    padding: 20px 16px 18px;
    color: #F2EAE0;
    cursor: pointer;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    font-family: inherit;
    overflow: hidden;
    transform-style: preserve-3d;
    transition:
      transform var(--dur-med) var(--ease-out),
      border-color var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out),
      background var(--dur-med) var(--ease-out);
  }
  .ninja-card:hover,
  .ninja-card:focus-visible {
    transform: translateY(-6px);
    border-color: var(--card-accent, var(--orange));
    background: linear-gradient(180deg, rgba(244, 121, 32, 0.06), rgba(255, 255, 255, 0.02));
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.35),
      0 0 0 1px var(--card-accent, var(--orange)),
      0 0 42px rgba(244, 121, 32, 0.30);
    outline: none;
  }
  .ninja-card:active { transform: translateY(-3px) scale(0.99); }
  .ninja-card.is-chosen {
    transform: translateY(-6px) scale(1.03);
    border-color: var(--card-accent, var(--orange));
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.45),
      0 0 0 2px var(--card-accent, var(--orange)),
      0 0 60px rgba(244, 121, 32, 0.45);
  }

  /* accent per role */
  .accent-sensei    { --card-accent: var(--role-sensei); }
  .accent-creative  { --card-accent: var(--role-creative); }
  .accent-architect { --card-accent: #C48A3E; }  /* brighter bronze on dark bg */
  .accent-ally      { --card-accent: #B5AFA6; }  /* lighter charcoal on dark bg */

  .card-glow {
    position: absolute; inset: -2px;
    border-radius: inherit;
    background:
      radial-gradient(60% 40% at 50% 0%, var(--card-accent, var(--orange)), transparent 70%);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-med) var(--ease-out);
    z-index: 0;
    filter: blur(20px);
  }
  .ninja-card:hover .card-glow,
  .ninja-card:focus-visible .card-glow,
  .ninja-card.is-chosen .card-glow { opacity: 0.35; }

  .card-portrait {
    position: relative;
    width: 100%;
    max-width: 200px;
    aspect-ratio: 1;
    display: flex; align-items: center; justify-content: center;
    z-index: 1;
    transition: transform var(--dur-med) var(--ease-out), filter var(--dur-med) var(--ease-out);
  }
  :global(.ninja-card .card-portrait img) {
    width: 100%; height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.5));
    transition: filter var(--dur-med) var(--ease-out);
  }
  .ninja-card:hover .card-portrait,
  .ninja-card:focus-visible .card-portrait { transform: scale(1.05); }
  :global(.ninja-card:hover .card-portrait img),
  :global(.ninja-card:focus-visible .card-portrait img) {
    filter: drop-shadow(0 8px 32px rgba(244, 121, 32, 0.55));
  }

  .card-meta { position: relative; z-index: 1; }
  .card-name {
    font-family: var(--font-display); font-weight: 800;
    font-size: 18px; letter-spacing: 1px; text-transform: uppercase;
    color: #FFFFFF;
    line-height: 1.1;
  }
  .card-role {
    font-family: var(--font-display); font-weight: 700;
    font-size: 11px; letter-spacing: 1.4px; text-transform: uppercase;
    color: var(--card-accent, var(--orange));
    margin-top: 4px;
  }
  .card-quote {
    font-size: 12.5px;
    color: #C8BFB5;
    font-style: italic;
    line-height: 1.4;
    margin-top: 10px;
    max-width: 220px;
  }

  /* Guest link */
  .guest-link {
    margin-top: 4px;
    display: inline-block;
    background: transparent; border: none;
    color: #B0A69B;
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.4px;
    font-size: 12.5px;
    cursor: pointer;
    padding: 10px 16px;
    border-radius: var(--r-md);
    border-bottom: 1px solid rgba(176, 166, 155, 0.35);
    transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }
  .guest-link:hover, .guest-link:focus-visible {
    color: var(--orange);
    border-color: var(--orange);
    outline: none;
  }

  /* =====================================================================
     ACT 1 · THE CALL
     ===================================================================== */
  .call-inner {
    position: relative;
    max-width: 720px; text-align: center;
    z-index: 1;
  }
  .call-kicker {
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 4px;
    font-size: 12px; color: var(--orange);
    margin-bottom: 18px;
  }
  .call-title {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(40px, 7vw, 78px); line-height: 0.98;
    color: #FFFFFF; text-transform: uppercase; letter-spacing: 1px;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.4);
  }
  .call-title .orange { color: var(--orange); }
  .call-emblem {
    display: flex; justify-content: center;
    margin-top: 26px;
  }
  .call-emblem img {
    display: none;
    width: min(320px, 68vw); height: auto;
    filter: drop-shadow(0 14px 44px rgba(244, 121, 32, 0.35));
  }
  .call-emblem img.is-active { display: block; }
  .call-lead {
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px;
    font-size: clamp(15px, 2.2vw, 20px);
    color: #F2EAE0; margin: 22px 0 0;
    opacity: 0.95;
  }
  .call-body {
    font-size: clamp(15px, 1.6vw, 17px);
    color: #C8BFB5; line-height: 1.55;
    max-width: 560px; margin: 20px auto 0;
  }
  .call-ask {
    font-family: var(--font-display); font-weight: 800;
    text-transform: uppercase; letter-spacing: 3px;
    font-size: clamp(18px, 2.6vw, 24px);
    color: var(--orange);
    margin: 34px 0 22px;
  }
  .call-actions {
    display: flex; justify-content: center; align-items: center;
    gap: 18px; flex-wrap: wrap;
  }
  .btn-accept {
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(180deg, var(--orange), var(--deep));
    color: var(--white);
    font-family: var(--font-display); font-weight: 800;
    text-transform: uppercase; letter-spacing: 1.6px;
    font-size: 15px;
    padding: 14px 26px;
    border: none;
    border-radius: var(--r-md); text-decoration: none;
    cursor: pointer;
    box-shadow: var(--shadow-orange), var(--shadow-2);
    transition: transform var(--dur-med) var(--ease-out), box-shadow var(--dur-med) var(--ease-out);
    animation: accept-pulse 3.6s ease-in-out infinite;
  }
  .btn-accept:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 30px rgba(244, 121, 32, 0.45), var(--shadow-3);
  }
  @keyframes accept-pulse {
    0%, 100% { box-shadow: var(--shadow-orange), var(--shadow-2); }
    50%      { box-shadow: 0 6px 28px rgba(244, 121, 32, 0.45), var(--shadow-2); }
  }
  .btn-skip {
    color: #B0A69B;
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.4px;
    font-size: 12.5px;
    text-decoration: none;
    border-bottom: 1px solid rgba(176, 166, 155, 0.35);
    padding-bottom: 2px;
    transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }
  .btn-skip:hover { color: var(--orange); border-color: var(--orange); }
  .call-hint {
    margin-top: 44px;
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 4px;
    font-size: 10px; color: #7A736A;
    animation: hint-bob 2.4s ease-in-out infinite;
  }
  @keyframes hint-bob {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(4px); opacity: 1; }
  }

  /* Identity chip — persistent reminder of who's in the room */
  .call-chip {
    position: absolute;
    top: 20px; right: 20px;
    display: flex; align-items: center; gap: 8px;
    padding: 8px 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--r-pill);
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px;
    font-size: 11px;
    color: #E8E0D6;
    backdrop-filter: blur(6px);
    z-index: 2;
  }
  .chip-arrow { color: var(--orange); }
  .chip-name { color: #FFFFFF; }
  .chip-sep { color: rgba(255, 255, 255, 0.3); }
  .chip-reset {
    background: none; border: none;
    color: #B0A69B; font: inherit; text-transform: inherit;
    letter-spacing: inherit; cursor: pointer;
    text-decoration: underline; text-underline-offset: 2px;
    padding: 0;
  }
  .chip-reset:hover { color: var(--orange); }
  @media (max-width: 640px) {
    .call-chip { top: 14px; right: 14px; font-size: 10px; padding: 6px 10px; }
  }

  /* Staggered fade-in — shared by Picker + Call */
  .fade { opacity: 0; animation: fade-up 700ms var(--ease-out) forwards; }
  .fade-1 { animation-delay: 100ms; }
  .fade-2 { animation-delay: 350ms; }
  .fade-3 { animation-delay: 700ms; }
  .fade-4 { animation-delay: 1050ms; }
  .fade-5 { animation-delay: 1400ms; }
  .fade-6 { animation-delay: 1700ms; }
  .fade-7 { animation-delay: 2100ms; }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: none; }
  }

  /* =====================================================================
     Shared scene shell (Origin, Philosophies, Phase, Dojo)
     ===================================================================== */
  .scene {
    padding: 72px 0;
    scroll-margin-top: calc(var(--bar-h) + 8px);
    /* Full-bleed so per-scene background bands span the viewport,
       breaking out of the layout's .wrap max-width + padding.
       Must be 100vw (not 100%) — 100% resolves to .wrap's 960px and
       left-anchors the band on wide screens. */
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }
  .scene-wrap { max-width: var(--wrap-max); margin: 0 auto; padding: 0 24px; }
  .scene-kicker {
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 3px;
    font-size: 12px; color: var(--deep);
    margin-bottom: 10px;
  }
  .scene-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800; margin-bottom: 12px;
    text-transform: none; letter-spacing: 0;
  }
  .scene-lede {
    font-size: 16px; color: var(--gray);
    max-width: 680px; margin-bottom: 12px;
    line-height: 1.6;
  }
  .scene-origin { background: linear-gradient(180deg, transparent, rgba(250, 247, 242, 0.6)); }
  .scene-phase { background: transparent; }
  .scene-dojo { background: linear-gradient(180deg, var(--paper) 0%, var(--white) 60%); }

  /* =====================================================================
     PHILOSOPHIES — the sacred scroll. Dark band. Cream cards. Ornaments.
     ===================================================================== */
  .scene-philosophies {
    position: relative;
    color: #F2EAE0;
    padding: 96px 0 100px;
    background:
      radial-gradient(900px 500px at 50% -20%, rgba(244, 121, 32, 0.15), transparent 65%),
      radial-gradient(700px 400px at 15% 100%, rgba(244, 121, 32, 0.06), transparent 70%),
      linear-gradient(180deg, #1A1614 0%, #14100E 55%, #0F0C0A 100%);
    border-top: 1px solid rgba(244, 121, 32, 0.15);
    border-bottom: 1px solid rgba(244, 121, 32, 0.15);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.35) inset,
      0 -20px 60px rgba(0, 0, 0, 0.35) inset;
    overflow: hidden;
  }
  .scene-philosophies::before {
    content: ''; position: absolute; inset: 0;
    background: var(--texture-paper);
    opacity: 0.35;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  .scene-philosophies .scene-wrap { position: relative; z-index: 1; }

  /* Ornamental divider above the title */
  .phil-ornament {
    text-align: center;
    margin-bottom: 18px;
    color: var(--orange);
    font-size: 12px;
    letter-spacing: 0;
    line-height: 1;
    opacity: 0.85;
  }
  .phil-ornament::before,
  .phil-ornament::after {
    content: '';
    display: inline-block;
    width: 72px; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(244, 121, 32, 0.7), transparent);
    vertical-align: middle;
    margin: 0 14px;
  }
  .phil-ornament span {
    display: inline-block;
    vertical-align: middle;
    text-shadow: 0 0 8px rgba(244, 121, 32, 0.7);
  }

  /* Fancy title stack */
  .phil-kicker {
    text-align: center;
    color: var(--orange);
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 3px;
    margin-bottom: 18px;
    opacity: 0.95;
  }
  .phil-title {
    text-align: center;
    font-family: var(--font-display);
    font-weight: 800;
    color: #FFFFFF;
    line-height: 1;
    margin: 0 auto 20px;
    text-transform: none;
    letter-spacing: 0;
  }
  .phil-title-lead {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.2vw, 26px);
    color: #E4D7C8;
    letter-spacing: 4px;
    text-transform: none;
    margin-bottom: 8px;
    opacity: 0.9;
  }
  .phil-title-main {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(46px, 8vw, 96px);
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: 2px;
    background: linear-gradient(180deg, #FFFFFF 0%, #F5E9D5 55%, #F4C88E 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-shadow: 0 4px 40px rgba(244, 121, 32, 0.35);
  }
  .phil-title-tail {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 2.2vw, 24px);
    color: var(--orange);
    letter-spacing: 2px;
    margin-top: 12px;
    text-transform: none;
  }
  .phil-lede {
    text-align: center;
    color: #C8BFB5;
    max-width: 640px;
    margin: 0 auto 18px;
    font-size: 15.5px;
    line-height: 1.65;
    font-style: italic;
  }

  /* Incense drift layer — scoped to the section, taps pass through */
  .phil-smoke {
    position: absolute; inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .phil-smoke svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .phil-smoke .w {
    filter: blur(14px);
    opacity: 0.05;
    animation: phil-drift 28s ease-in-out infinite;
  }
  .phil-smoke .w2 { animation-duration: 38s; animation-delay: -14s; opacity: 0.035; }
  .phil-smoke .w3 { animation-duration: 46s; animation-delay: -24s; opacity: 0.045; }
  @keyframes phil-drift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50%      { transform: translate(30px, -54px) rotate(2deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .phil-smoke .w { animation: none; }
  }

  /* Ink-brush stroke under the header */
  .phil-brush {
    max-width: 320px;
    margin: 0 auto 60px;
  }
  .phil-brush svg {
    display: block; width: 100%; height: 24px;
    filter: drop-shadow(0 0 10px rgba(244, 121, 32, 0.35));
  }

  /* =====================================================================
     Kakemono — three hanging scrolls
     ===================================================================== */
  .phil-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 30px; margin-top: 8px;
    align-items: start;
  }
  .phil-card {
    position: relative;
    text-align: center;
    /* Unroll reveal: clipped shut until in view */
    clip-path: inset(0 -30px 100% -30px);
    opacity: 0;
    transition:
      clip-path 900ms var(--ease-out),
      opacity 500ms var(--ease-out);
  }
  .phil-card.is-in-view {
    clip-path: inset(-30px -30px -30px -30px);
    opacity: 1;
  }
  .phil-card.is-in-view.phil-card-1 { transition-delay: 120ms; }
  .phil-card.is-in-view.phil-card-2 { transition-delay: 300ms; }
  .phil-card.is-in-view.phil-card-3 { transition-delay: 480ms; }

  /* Hanging cord + knot above the top rod */
  .kake-cord {
    width: 2px; height: 26px;
    margin: 0 auto;
    background: linear-gradient(180deg, rgba(244, 200, 142, 0.0), rgba(244, 200, 142, 0.55));
    position: relative;
  }
  .kake-cord::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 50%;
    width: 7px; height: 7px;
    transform: translateX(-50%) rotate(45deg);
    background: #C48A3E;
    box-shadow: 0 0 6px rgba(244, 121, 32, 0.5);
  }

  /* Wooden rods — top + bottom, slightly wider than the parchment */
  .kake-rod {
    height: 13px;
    width: calc(100% + 20px);
    margin: 0 -10px;
    border-radius: 7px;
    background: linear-gradient(180deg, #4E3B2A 0%, #2C2018 55%, #1B130D 100%);
    box-shadow:
      0 3px 8px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(244, 200, 142, 0.25);
    position: relative;
    z-index: 2;
  }
  .kake-rod::before,
  .kake-rod::after {
    content: '';
    position: absolute;
    top: 50%; transform: translateY(-50%);
    width: 9px; height: 17px;
    border-radius: 5px;
    background: linear-gradient(180deg, #3A2B1E, #140E09);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
  }
  .kake-rod::before { left: -4px; }
  .kake-rod::after  { right: -4px; }
  .kake-rod-b { margin-top: 0; }

  /* Parchment body */
  .kake-body {
    position: relative;
    background: linear-gradient(180deg, #FBF6EC 0%, #F3E7D0 78%, #EBDCBE 100%);
    margin: 0 2px;
    padding: 34px 24px 30px;
    color: var(--charcoal);
    overflow: hidden;
    box-shadow:
      0 24px 50px rgba(0, 0, 0, 0.5),
      inset 0 12px 18px -14px rgba(60, 40, 20, 0.5),
      inset 0 -12px 18px -14px rgba(60, 40, 20, 0.45);
    transition:
      transform var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out);
  }
  .kake-body::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--texture-paper);
    opacity: 0.55;
    pointer-events: none;
  }
  .phil-card:hover .kake-body {
    transform: translateY(-5px);
    box-shadow:
      0 34px 64px rgba(0, 0, 0, 0.6),
      0 0 36px rgba(244, 121, 32, 0.22),
      inset 0 12px 18px -14px rgba(60, 40, 20, 0.5),
      inset 0 -12px 18px -14px rgba(60, 40, 20, 0.45);
  }

  /* Faint kanji signature behind the content */
  .kake-kanji {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 190px;
    line-height: 1;
    color: rgba(61, 61, 61, 0.055);
    user-select: none;
    pointer-events: none;
  }
  .kake-content { position: relative; z-index: 1; }

  /* Brush-painted roman numerals — inline SVG strokes, ink-displaced */
  .phil-roman {
    margin-bottom: 16px;
    line-height: 0;
  }
  .phil-roman .rn {
    height: clamp(46px, 6vw, 62px);
    width: auto;
    display: inline-block;
    filter: drop-shadow(0 2px 10px rgba(244, 121, 32, 0.3));
  }

  .phil-h {
    font-size: clamp(19px, 2.1vw, 23px);
    margin: 0 0 10px;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.18;
    color: var(--charcoal);
    font-weight: 800;
  }

  .phil-sub {
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-size: 14.5px;
    color: var(--deep);
    margin: 0 0 18px;
    letter-spacing: 0.4px;
  }
  .phil-sub::after {
    content: '';
    display: block;
    width: 44px; height: 1px;
    background: rgba(228, 105, 0, 0.45);
    margin: 14px auto 0;
  }

  .phil-points {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 250px;
    text-align: left;
  }
  .phil-points li {
    position: relative;
    padding: 5px 0 5px 18px;
    font-size: 13.8px;
    color: #4A423A;
    line-height: 1.5;
  }
  .phil-points li::before {
    content: '◆';
    position: absolute;
    left: 0; top: 7px;
    font-size: 8px;
    color: var(--orange);
  }

  /* Origin — portrait + moat (unchanged) */
  .portrait-wrap { float: right; width: 220px; margin: 6px 0 16px 24px; text-align: center; }
  :global(.portrait-wrap .portrait-img) {
    width: 100%; height: auto; display: block; border-radius: 50%;
    border: 3px solid var(--orange); box-shadow: var(--shadow-2); background: var(--white);
  }
  .portrait-caption {
    margin-top: 10px; font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px; font-size: 11px; color: var(--gray); line-height: 1.3;
  }
  @media (max-width: 640px) { .portrait-wrap { float: none; width: 160px; margin: 18px auto; } }

  .moat {
    max-width: 900px; margin: 8px auto 0;
    display: grid; grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center; gap: 18px; padding: 20px 24px;
    background: linear-gradient(180deg, var(--white), var(--paper));
    border: 1px solid var(--line); border-radius: var(--r-lg);
    box-shadow: var(--shadow-2), var(--shadow-inner-hairline); position: relative;
  }
  .moat::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
    background: linear-gradient(180deg, var(--orange), var(--deep));
    border-radius: var(--r-lg) 0 0 var(--r-lg);
  }
  .moat-item { text-align: center; }
  .moat-n { font-family: var(--font-display); font-weight: 800;
    font-size: clamp(30px, 4.5vw, 44px); line-height: 1;
    color: var(--charcoal); letter-spacing: 0.5px; }
  .moat-n .plus { color: var(--orange); }
  .moat-n .unit { font-size: 0.5em; color: var(--gray); font-weight: 700; letter-spacing: 1px; }
  .moat-l { font-size: 12px; text-transform: uppercase; letter-spacing: 1.2px;
    color: var(--gray); margin-top: 8px; font-weight: 600; }
  .moat-sep { width: 1px; height: 46px;
    background: linear-gradient(180deg, transparent, var(--line), transparent); }

  /* Next Phase (unchanged) */
  .phase-actions { display: flex; gap: 14px; margin-top: 20px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(180deg, var(--orange), var(--deep));
    color: var(--white); text-decoration: none;
    font-family: var(--font-display); font-weight: 800;
    text-transform: uppercase; letter-spacing: 1.4px;
    font-size: 14px; padding: 13px 22px; border-radius: var(--r-md);
    box-shadow: var(--shadow-2), 0 0 0 1px rgba(244, 121, 32, 0.15);
    transition: transform var(--dur-med) var(--ease-out), box-shadow var(--dur-med) var(--ease-out);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-3), 0 8px 22px var(--orange-glow); }
  .btn-ghost {
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--deep); background: var(--white); border: 1px solid var(--line);
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.2px;
    font-size: 13px; padding: 12px 20px; border-radius: var(--r-md); text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }
  .btn-ghost:hover { background: var(--focus); border-color: var(--orange); }

  /* Dojo (unchanged) */
  .head-row { display: grid; grid-template-columns: minmax(72px, 170px) 1fr minmax(72px, 170px);
    align-items: center; gap: 18px; max-width: 980px; margin: 0 auto; }
  .dojo-head { text-align: center; margin-bottom: 4px; }
  .head-flank { width: 100%; max-width: 170px; height: auto; justify-self: center; }
  .head-flank-left { transform: scaleX(-1); }
  .dojo-head h2 { font-size: 36px; font-weight: 800; margin-top: 6px; }
  .dojo-head .sub { font-size: 15px; color: var(--gray); margin-top: 4px; }
  .wall { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 30px; }
  .tagline { text-align: center; margin-top: 28px; font-family: var(--font-display);
    font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--deep); }

  /* =====================================================================
     Responsive
     ===================================================================== */
  @media (max-width: 900px) {
    .ninja-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
  @media (max-width: 800px) {
    .phil-grid { grid-template-columns: 1fr; gap: 40px; }
    .kake-kanji { font-size: 150px; }
    .phil-brush { margin-bottom: 44px; }
    /* Single column: stagger reads as one long fall — tighten delays */
    .phil-card.is-in-view.phil-card-2 { transition-delay: 160ms; }
    .phil-card.is-in-view.phil-card-3 { transition-delay: 200ms; }
  }
  @media (prefers-reduced-motion: reduce) {
    .phil-card { transition: none; }
    .kake-body { transition: none; }
  }
  @media (max-width: 900px) {
    .ninja-grid {
      display: flex;
      gap: 12px;
      margin: 28px -2px 20px;
      padding: 2px 2px 10px;
      overflow-x: auto;
      overflow-y: visible;
      scroll-snap-type: x mandatory;
      scroll-padding-inline: 2px;
      overscroll-behavior-x: contain;
      -webkit-overflow-scrolling: touch;
      touch-action: pan-x;
    }
    .ninja-grid::-webkit-scrollbar { height: 6px; }
    .ninja-grid::-webkit-scrollbar-thumb {
      background: rgba(244, 121, 32, 0.5);
      border-radius: 999px;
    }
    .ninja-grid::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.08); }
    .ninja-card {
      flex: 0 0 min(76vw, 320px);
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }
  }

  @media (max-width: 640px) {
    .head-row { grid-template-columns: 1fr; gap: 10px; }
    .head-flank { max-width: 150px; opacity: 0.92; }
    .wall { grid-template-columns: 1fr 1fr; }
    .moat { grid-template-columns: 1fr; padding: 16px 18px; }
    .moat-sep { width: 60%; height: 1px; justify-self: center;
                background: linear-gradient(90deg, transparent, var(--line), transparent); }
    .scene { padding: 56px 0; }
    .scene-picker, .scene-call { padding: 40px 20px; }
    .picker-title { font-size: clamp(36px, 10vw, 56px); }
    .card-portrait { max-width: 140px; }
    .card-name { font-size: 15px; }
  }
  @media (max-width: 480px) {
    .wall { grid-template-columns: 1fr; }
    .ninja-card { flex-basis: min(84vw, 320px); }
    .card-portrait { max-width: 180px; }
    .call-actions { flex-direction: column; gap: 14px; }
    .btn-accept, .btn-skip { min-height: 44px; }
  }

  /* =====================================================================
     PHASE GATE — controls which acts are visible
     [data-phase="picker"] → only .scene-picker
     [data-phase="call"]   → only .scene-call
     (no data-phase)       → everything visible (accepted / guest)
     ===================================================================== */
  :global(html[data-phase="picker"]) .scene-call,
  :global(html[data-phase="picker"]) .scene,
  :global(html[data-phase="picker"]) .footer { display: none !important; }

  :global(html[data-phase="call"]) .scene-picker,
  :global(html[data-phase="call"]) .scene,
  :global(html[data-phase="call"]) .footer { display: none !important; }

  /* Reveal animation when phase clears */
  :global(html:not([data-phase])) .scene {
    animation: scene-reveal 700ms var(--ease-out) both;
  }
  :global(html:not([data-phase])) .scene-origin       { animation-delay: 100ms; }
  :global(html:not([data-phase])) .scene-philosophies { animation-delay: 260ms; }
  :global(html:not([data-phase])) .scene-phase        { animation-delay: 420ms; }
  :global(html:not([data-phase])) .scene-dojo         { animation-delay: 580ms; }
  @keyframes scene-reveal {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .fade, .btn-accept, .call-hint {
      animation: none !important;
      opacity: 1 !important; transform: none !important;
    }
    :global(html:not([data-phase])) .scene { animation: none !important; }
  }
</style>

<script is:inline>
  /* =====================================================================
     Identity + phase orchestration
     Picker card click  → save identity, personalize Call, switch to "call"
     Accept button      → save accepted flag, unlock everything
     Guest link         → save guest identity + accepted, unlock everything
     Reset "not you?"   → clear identity, drop back to "picker"
     ===================================================================== */
  (function () {
    var IDENTITIES = {
      tim:   { name: 'Tim',   action: 'LEAD',      sub: 'The Dojo is yours to build.' },
      gabe:  { name: 'Gabe',  action: 'TELL',      sub: 'Every frame is your canvas.' },
      pavan: { name: 'Pavan', action: 'BUILD',     sub: 'The systems are yours to wire.' },
      erik:  { name: 'Erik',  action: 'BROADCAST', sub: 'Lucky 13 is the home stage.' },
      guest: { name: 'Guest', action: 'EXPLORE',   sub: 'Take a look around.' }
    };

    function personalizeCall(id) {
      var m = IDENTITIES[id]; if (!m) return;
      var chip = document.getElementById('chip-name');
      if (chip) chip.textContent = m.name;
      var imgs = document.querySelectorAll('#call-emblem img');
      imgs.forEach(function (img) {
        img.classList.toggle('is-active', img.getAttribute('data-for') === id);
      });
    }

    function setPhase(next) {
      if (next === null) delete document.documentElement.dataset.phase;
      else document.documentElement.dataset.phase = next;
    }

    function syncPhaseFromStorage() {
      var id = null;
      var ok = null;
      try {
        id = localStorage.getItem('dojo:identity');
        ok = localStorage.getItem('dojo:accepted');
      } catch (_) {}

      if (!id) setPhase('picker');
      else if (!ok) setPhase('call');
      else setPhase(null);

      // iOS Safari can occasionally retain a stale non-scrollable state
      // across page restores, so force-clear inline overflow when unlocked.
      if (!document.documentElement.dataset.phase) {
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
      }
    }

    function scrollToId(id) {
      var el = document.getElementById(id);
      if (el) requestAnimationFrame(function () {
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    function saveIdentity(id)  { try { localStorage.setItem('dojo:identity', id); } catch(_){} }
    function saveAccepted()    { try { localStorage.setItem('dojo:accepted', 'true'); } catch(_){} }
    function clearIdentity()   { try {
      localStorage.removeItem('dojo:identity');
      localStorage.removeItem('dojo:accepted');
    } catch(_){} }

    function wire() {
      syncPhaseFromStorage();

      // On load: if identity already exists (returning visitor), personalize Call now
      var storedId = null;
      try { storedId = localStorage.getItem('dojo:identity'); } catch(_) {}
      if (storedId) personalizeCall(storedId);

      // Picker cards → choose identity
      var cards = document.querySelectorAll('[data-ninja]');
      cards.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-ninja');
          if (!id) return;
          var isGuest = btn.getAttribute('data-guest') === 'true';

          // Chosen-state animation on the card (skipped for guest)
          if (!isGuest) {
            cards.forEach(function (c) { c.classList.remove('is-chosen'); });
            btn.classList.add('is-chosen');
            btn.setAttribute('aria-checked', 'true');
          }
          saveIdentity(id);
          personalizeCall(id);

          if (isGuest) {
            // Guest goes straight in — skip Call entirely
            saveAccepted();
            setTimeout(function () {
              setPhase(null);
              scrollToId('origin');
            }, 250);
          } else {
            // Short pause for the chosen-state animation to read, then transition to Call
            setTimeout(function () {
              setPhase('call');
              window.scrollTo({ top: 0, behavior: 'auto' });
            }, 550);
          }
        });
      });

      // Accept button → lock in accepted, unlock everything, scroll to Origin
      var accept = document.getElementById('accept-btn');
      if (accept) accept.addEventListener('click', function () {
        saveAccepted();
        setPhase(null);
        scrollToId('origin');
      });

      // "not you?" reset — clear identity + drop back to picker
      var reset = document.getElementById('reset-identity');
      if (reset) reset.addEventListener('click', function () {
        clearIdentity();
        setPhase('picker');
        window.scrollTo({ top: 0, behavior: 'auto' });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wire);
    } else { wire(); }

    window.addEventListener('pageshow', syncPhaseFromStorage);
  })();

  /* Philosophy card reveal — trigger the fade+lift when cards scroll into view */
  (function () {
    function reveal() {
      var cards = document.querySelectorAll('.phil-card');
      if (!cards.length) return;
      if (!('IntersectionObserver' in window)) {
        cards.forEach(function (c) { c.classList.add('is-in-view'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('is-in-view');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.2, rootMargin: '0px 0px -60px 0px' });
      cards.forEach(function (c) { io.observe(c); });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', reveal);
    } else { reveal(); }
  })();
</script>
