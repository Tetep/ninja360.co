---
// Home — the Dojo wall under the torii.
// Reads all room entries and renders a door per entry, in order.
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import DojoLayout from '../layouts/DojoLayout.astro';
import Torii from '../components/Torii.astro';
import Door from '../components/Door.astro';
import { doorImages, heroFlankImage } from '../assets/doors';

const rooms = (await getCollection('rooms')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<DojoLayout title="The Ninja-360 Dojo">
  <section aria-labelledby="dojo-heading">
    <div class="head-row">
      <Image
        class="head-flank head-flank-left"
        src={heroFlankImage}
        alt=""
        loading="lazy"
        widths={[180, 260, 360]}
        sizes="(max-width: 640px) 150px, 170px"
      />
      <div class="home-head">
        <Torii />
        <h1 id="dojo-heading">Welcome to the Dojo</h1>
        <div class="sub">Where we put local businesses on the map, tell their true stories beautifully, and sharpen the blade every single week.</div>
        <p class="intro">The Ninja-360 Dojo — the plan, the crew, and the playbooks in one place. New here? Start with the Game Plan.</p>
        <div class="spine-links">
          <a class="spine-link start-here" href="/gameplan">Start Here &rarr; The Game Plan</a>
          <a class="spine-link" href="/scrolls">The Scrolls</a>
        </div>
      </div>
      <Image
        class="head-flank head-flank-right"
        src={heroFlankImage}
        alt=""
        loading="lazy"
        widths={[180, 260, 360]}
        sizes="(max-width: 640px) 150px, 170px"
      />
    </div>

    <div class="moat" aria-label="Ninja-360 authority signals">
      <div class="moat-item">
        <div class="moat-n">90M<span class="plus">+</span></div>
        <div class="moat-l">Google Photos &amp; Virtual Tour views</div>
      </div>
      <div class="moat-sep" aria-hidden="true"></div>
      <div class="moat-item">
        <div class="moat-n">2<span class="plus">+</span> <span class="unit">decades</span></div>
        <div class="moat-l">documenting the Kansas City metro</div>
      </div>
      <div class="moat-sep" aria-hidden="true"></div>
      <div class="moat-item">
        <div class="moat-n">KC<span class="plus">.</span></div>
        <div class="moat-l">Owner-operated from Gladstone, MO</div>
      </div>
    </div>

    <div class="creed">
      <div class="cr"><b>Become the name</b>Ninja-360 is the one KC thinks of for getting found.</div>
      <div class="cr"><b>Your work makes the show</b>One client visit = the deliverable + an episode of "Found in KC."</div>
      <div class="cr"><b>Everyone builds together</b>A crew, not employees. Each grows their own while building yours.</div>
    </div>

    <div class="wallnote">— Seven doors · the journey —</div>

    <div class="wall">
      {rooms.map(r => (
        <Door
          href={`/${r.slug}`}
          num={r.data.doorNum}
          lintel={r.data.doorLabel}
          name={r.data.title.split('—')[0].trim().replace(/^The\s+/, '')}
          sub={r.data.subtitle}
          imageSrc={doorImages[r.slug as keyof typeof doorImages]}
          variant={r.slug === 'floor' ? 'floor' : 'default'}
        />
      ))}
      {/* Parked "Someday" tile — not a room */}
      <Door
        href="#"
        num="★"
        lintel="Someday"
        name="The App"
        sub="This board, upgraded · parked"
        variant="parked"
      />
    </div>

    <div class="philo-strip">
      <a class="ph" href="/vision"><b>Put People on the Map</b>visible, heard, chosen.</a>
      <a class="ph" href="/forge"><b>Fall in Love with the True Story</b>technology is the tool; connection is the goal.</a>
      <a class="ph" href="/floor"><b>Always Sharpen the Blade</b>try, fail, learn, improve &mdash; responsibly.</a>
    </div>

    <p class="tagline">Run the rhythm. The rhythm runs the plan.</p>
  </section>
</DojoLayout>

<style>
  .head-row {
    display: grid;
    grid-template-columns: minmax(72px, 170px) 1fr minmax(72px, 170px);
    align-items: center;
    gap: 18px;
    max-width: 980px;
    margin: 0 auto;
  }
  .home-head { text-align: center; margin-bottom: 4px; }
  .head-flank {
    width: 100%;
    max-width: 170px;
    height: auto;
    justify-self: center;
  }
  .head-flank-left { transform: scaleX(-1); }
  .home-head h1 { font-size: 44px; font-weight: 800; }
  .home-head .sub { font-size: 17px; color: var(--gray); margin-top: 4px; }
  .spine-links {
    margin-top: 10px;
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .spine-link {
    border: 1px solid var(--line);
    background: var(--warm);
    color: var(--deep);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 6px 10px;
    border-radius: var(--r-md);
    font-size: 12px;
  }
  .intro {
    font-size: 14.5px;
    color: var(--gray);
    max-width: 460px;
    margin: 8px auto 0;
  }
  .spine-link.primary {
    background: var(--charcoal);
    border-color: var(--charcoal);
    color: var(--white);
  }
  .spine-link.start-here {
    background: var(--orange);
    border-color: var(--orange);
    color: var(--white);
    font-size: 14px;
    padding: 11px 18px;
  }
  .spine-link:hover { background: var(--focus); }
  .spine-link.primary:hover { opacity: 0.92; }
  .spine-link.start-here:hover { background: var(--deep); border-color: var(--deep); }

  /* ==== Moat strip — the 90M+ authority signal ==== */
  .moat {
    max-width: 900px;
    margin: 28px auto 8px;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 18px;
    padding: 18px 22px;
    background: linear-gradient(180deg, var(--white), var(--paper));
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-2), var(--shadow-inner-hairline);
    position: relative;
  }
  .moat::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--orange), var(--deep));
    border-radius: var(--r-lg) 0 0 var(--r-lg);
  }
  .moat-item { text-align: center; }
  .moat-n {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 40px;
    line-height: 1;
    color: var(--charcoal);
    letter-spacing: 0.5px;
  }
  .moat-n .plus { color: var(--orange); }
  .moat-n .unit {
    font-size: 20px; color: var(--gray); font-weight: 700;
    letter-spacing: 1px;
  }
  .moat-l {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--gray);
    margin-top: 6px;
    font-weight: 600;
  }
  .moat-sep {
    width: 1px;
    height: 44px;
    background: linear-gradient(180deg, transparent, var(--line), transparent);
  }
  @media (max-width: 640px) {
    .moat {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 16px 18px;
      max-width: 100%;
    }
    .moat-sep { width: 60%; height: 1px; justify-self: center;
                background: linear-gradient(90deg, transparent, var(--line), transparent); }
    .moat-n { font-size: 32px; }
  }

  .creed {
    max-width: 720px; margin: 18px auto 0;
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;
  }
  .cr {
    background: var(--white); border: 1px solid var(--line);
    border-radius: var(--r-md); padding: 12px 14px; font-size: 13px;
    box-shadow: var(--shadow-1);
    transition: box-shadow var(--dur-med) var(--ease-out), transform var(--dur-med) var(--ease-out);
  }
  .cr:hover { box-shadow: var(--shadow-2); transform: translateY(-1px); }
  .cr b {
    font-family: var(--font-display); font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--deep); font-size: 14px; display: block; margin-bottom: 2px;
  }

  .wallnote {
    text-align: center;
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px;
    color: var(--dead); font-size: 13px;
    margin: 24px 0 12px;
  }

  .wall { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }

  .philo-strip {
    max-width: 720px; margin: 22px auto 0;
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px;
  }
  .ph {
    background: var(--warm); border: 1px solid var(--line);
    border-radius: var(--r-md); padding: 10px 12px; font-size: 13px;
    color: inherit; text-decoration: none;
  }
  .ph b {
    font-family: var(--font-display); font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--deep); font-size: 14px; display: block; margin-bottom: 2px;
  }
  .ph:hover { background: var(--focus); }

  .tagline {
    text-align: center; margin-top: 22px;
    font-family: var(--font-display); font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--deep);
  }

  @media (max-width: 640px) {
    .head-row {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .head-flank {
      max-width: 150px;
      opacity: 0.92;
    }
    .wall { grid-template-columns: 1fr 1fr; }
    .creed { grid-template-columns: 1fr; }
    .philo-strip { grid-template-columns: 1fr; }
    .home-head h1 { font-size: 36px; }
  }

  @media (max-width: 480px) {
    .wall { grid-template-columns: 1fr; }
    .spine-link { min-height: 44px; display: inline-flex; align-items: center; }
  }
</style>
