---
import DojoLayout from '../../layouts/DojoLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<DojoLayout title="Pavan Roadmap · The Ninja-360 Dojo">
  <Breadcrumb trail={[{ label: 'Dojo', href: '/' }, { label: 'Crew', href: '/crew' }, { label: 'Pavan Roadmap' }]} />
  <a class="back" href="/crew">← Back to the Crew</a>
  <div class="source-row" aria-label="Source artifacts">
    <a class="source-chip" href="/scrolls/warp-speed">
      <span class="src-icon" aria-hidden="true">📜</span>
      <span class="src-label">Source</span>
      <span class="src-target">warp speed</span>
    </a>
  </div>
  <section class="frame-wrap" aria-labelledby="pavan-roadmap-title">
    <h2 id="pavan-roadmap-title">Pavan Roadmap</h2>
    <p class="epigraph">"A system is a blade that stays sharp on its own."</p>
    <p class="note">Legacy roadmap rendered inside the Dojo shell.</p>
    <iframe
      class="roadmap-frame"
      src="/legacy/roadmaps/pavan.html"
      title="Pavan roadmap"
      loading="lazy"
    ></iframe>
  </section>
</DojoLayout>

<style>
  .frame-wrap {
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 12px;
    background: var(--warm);
  }
  .frame-wrap h2 {
    font-size: 28px;
  }
  .epigraph {
    margin: 2px 0 0;
    font-style: italic;
    color: var(--deep);
  }
  .note {
    margin: 4px 0 10px;
    color: var(--gray);
  }
  .roadmap-frame {
    width: 100%;
    min-height: 80vh;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: var(--white);
  }
</style>
