---
import DojoLayout from '../../layouts/DojoLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
---

<DojoLayout title="Gabe Roadmap · The Ninja-360 Dojo">
  <Breadcrumb trail={[{ label: 'Dojo', href: '/' }, { label: 'Crew', href: '/crew' }, { label: 'Gabe Roadmap' }]} />
  <a class="back" href="/crew">← Back to the Crew</a>
  <section class="frame-wrap" aria-labelledby="gabe-roadmap-title">
    <h2 id="gabe-roadmap-title">Gabe Roadmap</h2>
    <p class="epigraph">"Fall in love with the true story &mdash; then tell it beautifully."</p>
    <p class="note">Legacy roadmap rendered inside the Dojo shell.</p>
    <iframe
      class="roadmap-frame"
      src="/legacy/roadmaps/gabe.html"
      title="Gabe roadmap"
      loading="lazy"
    ></iframe>
  </section>
</DojoLayout>

<style>
  .frame-wrap {
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 12px;
    background: var(--warm);
  }
  .frame-wrap h2 {
    font-size: 28px;
  }
  .epigraph {
    margin: 2px 0 0;
    font-style: italic;
    color: var(--deep);
  }
  .note {
    margin: 4px 0 10px;
    color: var(--gray);
  }
  .roadmap-frame {
    width: 100%;
    min-height: 80vh;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: var(--white);
  }
</style>
