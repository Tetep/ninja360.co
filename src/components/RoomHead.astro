---
// Room header — back link + kicker + title + the room's guide + source chips.
// Source chips render from `ref` frontmatter (single URL or array of URLs).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Guide from './Guide.astro';
type GuideKey = 'sensei' | 'creative' | 'architect' | 'ally';
interface Props {
  doorNum: string;
  doorLabel: string;
  title: string;
  guide: GuideKey;
  plain?: string;
  roomHeroImage?: ImageMetadata;
  ref?: string | string[];
}
const { doorNum, doorLabel, title, guide, plain, roomHeroImage, ref } = Astro.props;

// Normalize `ref` to an array of URL strings (or empty).
const sources: string[] = Array.isArray(ref) ? ref : ref ? [ref] : [];

// Best-effort label for a source URL — turn "/scrolls/kpi-gameplan" into "kpi-gameplan"
function labelFor(url: string): string {
  const clean = url.replace(/\/$/, '').split('/').filter(Boolean).pop() || url;
  return clean.replace(/-/g, ' ');
}
---

<a class="back" href="/">← Back to the Dojo</a>

<div class="rhead">
  <div class="rhead-main">
    <div class="k">Door {doorNum} · {doorLabel}</div>
    <h2>{title}</h2>
    {plain && <p class="plain">{plain}</p>}
    <div class="guide-row">
      <Guide guide={guide} variant="chip" size={44} />
      <span class="caption">{guide === 'sensei' ? 'Tim' : guide === 'creative' ? 'Gabe' : guide === 'architect' ? 'Pavan' : 'Erik'} guides you here</span>
    </div>
    {sources.length > 0 && (
      <div class="source-row" aria-label="Source artifacts">
        {sources.map(url => (
          <a class="source-chip" href={url} data-tip={labelFor(url)}>
            <span class="src-icon" aria-hidden="true">📜</span>
            <span class="src-label">Source</span>
            <span class="src-target">{labelFor(url)}</span>
          </a>
        ))}
      </div>
    )}
  </div>
  {roomHeroImage && (
    <div class="rhead-art">
      <Image
        src={roomHeroImage}
        alt={`${title} badge`}
        loading="lazy"
        widths={[180, 260, 360]}
        sizes="(max-width: 800px) 42vw, 170px"
      />
    </div>
  )}
</div>

<style>
  .rhead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .rhead-main { min-width: 0; }
  .plain {
    font-size: 15px;
    color: var(--gray);
    margin: 6px 0 0;
    max-width: 560px;
  }
  .rhead-art {
    width: 170px;
    flex: 0 0 auto;
  }
  :global(.rhead-art img) {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* .source-row / .source-chip styles live in base.css (also used by roadmap pages) */

  @media (max-width: 800px) {
    .rhead {
      flex-direction: column;
      align-items: flex-start;
    }
    .rhead-art { width: 140px; }
  }
</style>
