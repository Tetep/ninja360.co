---
// Sticky top nav. Present on every room. Home link + all rooms.
const pathname = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/', label: 'Dojo' },
  { href: '/gameplan', label: 'Game Plan' },
  { href: '/scrolls', label: 'Scrolls' },
  { href: '/vision', label: 'Vision' },
  { href: '/money', label: 'Money' },
  { href: '/assets', label: 'Assets' },
  { href: '/forge', label: 'Warp Speed' },
  { href: '/alliance', label: 'Alliance' },
  { href: '/crew', label: 'Crew' },
  { href: '/floor', label: 'The Floor' },
];
---

<div class="bar">
  <a class="wm" href="/">NINJA-360 · DOJO</a>
  <button
    class="menu-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="rooms-nav"
    aria-label="Toggle room menu"
  >
    <span></span><span></span><span></span>
  </button>
  <nav id="rooms-nav" aria-label="Rooms">
    {links.map(l => (
      <a href={l.href} aria-current={pathname === l.href ? 'page' : undefined}>{l.label}</a>
    ))}
  </nav>
</div>
<div class="accent"></div>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const bar = document.querySelector('.bar');
  toggle?.addEventListener('click', () => {
    const isOpen = bar?.classList.toggle('nav-open');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });
</script>
