---
// Torii gate — the visual anchor on the Home dojo wall.
// Uses the same simple 5-rect silhouette from the reference, sized responsively.
interface Props { size?: number; }
const { size = 130 } = Astro.props;
---

<svg class="torii" viewBox="0 0 130 90" width={size} height={size * (90/130)} aria-hidden="true" role="presentation">
  <rect x="6" y="16" width="118" height="9" rx="2" fill="var(--orange)"/>
  <rect x="16" y="27" width="98" height="6" rx="2" fill="var(--orange)"/>
  <rect x="26" y="33" width="10" height="52" fill="var(--charcoal)"/>
  <rect x="94" y="33" width="10" height="52" fill="var(--charcoal)"/>
  <rect x="2" y="6" width="126" height="8" rx="3" fill="var(--charcoal)"/>
</svg>

<style>
  .torii { display: block; margin: 6px auto 2px; }
</style>
