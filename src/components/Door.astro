---
// A door on the dojo wall.
// Props map to the room's frontmatter.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;           // "/vision" — leave undefined + parked=true for the Someday tile
  num: string;            // "01"
  lintel: string;         // "The Gate"
  name: string;           // "Vision"
  sub: string;            // "Found in KC · become the KPI"
  imageSrc?: ImageMetadata;
  variant?: 'default' | 'floor' | 'parked';
}
const { href, num, lintel, name, sub, imageSrc, variant = 'default' } = Astro.props;
const cls = `door door-${variant}${imageSrc ? ' has-art' : ''}`;
---

{variant === 'parked' ? (
  <div class={cls} aria-disabled="true" title="Parked — not yet built">
    <div class="lintel"><span>{lintel}</span><span class="num">{num}</span></div>
    <span class="panes"></span>
    <div class="name">
      <div class="t">{name}</div>
      <div class="s">{sub}</div>
    </div>
  </div>
) : (
  <a class={cls} href={href}>
    <div class="lintel"><span>{lintel}</span><span class="num">{num}</span></div>
    {imageSrc && (
      <div class="door-art-wrap" aria-hidden="true">
        <Image
          class="door-art"
          src={imageSrc}
          alt=""
          loading="lazy"
          widths={[200, 300, 420]}
          sizes="(max-width: 800px) 42vw, 220px"
        />
      </div>
    )}
    <span class="panes"></span>
    <span class="handle"></span>
    <div class="name">
      <div class="t">{name}</div>
      <div class="s">{sub}</div>
    </div>
  </a>
)}

<style>
  .door {
    position: relative; height: 200px;
    border: 6px solid var(--charcoal);
    border-radius: 5px;
    background: linear-gradient(180deg, #fff 0%, var(--paper) 62%, #F3ECDE 100%);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex; flex-direction: column;
    box-shadow: var(--shadow-1);
    transition:
      transform var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out),
      border-color var(--dur-med) var(--ease-out);
  }
  .door:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-3), 0 0 0 1px var(--orange);
    border-color: var(--charcoal);
  }
  .door:hover .handle {
    box-shadow: 0 0 0 4px var(--orange-glow), 0 0 12px var(--orange-glow);
    transform: scale(1.08);
  }
  .door-floor { border-color: var(--deep); }
  .door-floor:hover { box-shadow: var(--shadow-3), 0 0 0 1px var(--deep); }
  .door-parked { border-style: dashed; border-color: var(--dead); background: var(--warm); cursor: default; opacity: 0.85; box-shadow: none; }
  .door-parked:hover { transform: none; box-shadow: none; }

  .panes {
    position: absolute; inset: 10px;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 50% 33.33%;
    opacity: 0.45; z-index: 1;
  }
  .door-art-wrap {
    position: absolute;
    inset: 34px 12px 48px;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
  }
  :global(.door-art-wrap img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    opacity: 0.9;
    filter: saturate(1.08) contrast(1.06);
  }
  .has-art .panes {
    opacity: 0.1;
  }
  .has-art::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(255, 250, 241, 0.46) 10%, rgba(255, 250, 241, 0.08) 44%, rgba(255, 250, 241, 0) 82%);
    z-index: 1;
    pointer-events: none;
  }
  .lintel {
    background: var(--charcoal); color: #fff;
    padding: 6px 10px;
    font-family: var(--font-display); font-weight: 800;
    text-transform: uppercase; letter-spacing: 1px; font-size: 13px;
    display: flex; justify-content: space-between;
    position: relative; z-index: 2;
  }
  .lintel .num { color: var(--orange); }
  .door-floor .lintel { background: var(--deep); }
  .door-parked .lintel { background: var(--dead); }

  .name { margin-top: auto; padding: 11px 12px; position: relative; z-index: 2; }
  .name .t {
    font-family: var(--font-display); font-weight: 800;
    font-size: 19px; text-transform: uppercase; color: var(--charcoal);
    line-height: 1;
  }
  .name .s { font-size: 11.5px; color: var(--gray); margin-top: 3px; }

  .handle {
    position: absolute; right: 12px; top: 52%;
    width: 11px; height: 11px; border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #FFB166, var(--orange) 60%, var(--deep));
    box-shadow: 0 0 0 3px rgba(244, 121, 32, 0.2);
    z-index: 2;
    transition: transform var(--dur-med) var(--ease-out), box-shadow var(--dur-med) var(--ease-out);
  }
</style>
